PORT=3000

# ── Data layer switches ─────────────────────────────────────────
# Both default to the values shown below if unset.  See
# backend/src/dataModel/index.ts for the supported values and how
# to add a new backend.

# Which storage backend the repositories use.
#   json — JSON files under backend/data/ (default)
STORAGE_BACKEND=json

# Which validation-cache implementation to use.
#   memory — in-process Map with TTL (default)
CACHE_BACKEND=memory
